# Copier ce fichier en .env (non commité) et renseigner les vraies valeurs.

# --- Base de données ---
DATABASE_URL="postgresql://user:password@localhost:5432/generateur_cv?schema=public"

# --- NextAuth ---
# Génère un secret avec : openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# --- Provider OAuth Google (console.cloud.google.com > Identifiants) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- IA (déjà existant) ---
GROQ_API_KEY=""
GROQ_MODEL="openai/gpt-oss-120b"
OLLAMA_URL="http://localhost:11434"

